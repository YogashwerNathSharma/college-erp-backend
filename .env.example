# ===========================
# College ERP - Environment Variables
# ===========================

# Server
NODE_ENV=development
PORT=5000

# Database (MongoDB)
DATABASE_URL=mongodb://admin:admin123@localhost:27017/college_erp?authSource=admin

# Redis
REDIS_URL=redis://:redis123@localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Frontend URLs
FRONTEND_URL=http://localhost:5173
STUDENT_PORTAL_URL=http://localhost:5174

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SMS Gateway
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=ERPSMS

# WhatsApp API
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_API_TOKEN=your-whatsapp-token

# Razorpay (Payment Gateway)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# AWS S3 (Optional - for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=college-erp-uploads

# Super Admin
SUPER_ADMIN_EMAIL=admin@college-erp.com
SUPER_ADMIN_PASSWORD=Admin@123

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
