generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}


//////////////////////
// TENANT
//////////////////////
model Tenant {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name          String
  type          String
  logoUrl       String?
  backgroundUrl String?
  address String?
  phone   String?
  email   String?
  users         User[]
  academicYears AcademicYear[]
  classes       Class[]
  sections      Section[]
  students      Student[]
  subjects      Subject[]
  teachers      Teacher[]
  timetables    Timetable[]
  enrollments   Enrollment[]
  isDeleted Boolean @default(false)
  studentHistories  StudentHistory[]
  promotions        Promotion[]
  classAgeConfigs   ClassAgeConfig[]
  admissionCounters AdmissionCounter[]

  // Fee Module Relations
  feeHeads      FeeHead[]
  feeStructures FeeStructure[]
  feeDiscounts  FeeDiscount[]
  fineRules     FineRule[]
  studentFees   StudentFee[]
  payments      Payment[]

  subscriptions TenantSubscription[]

  currentSubscriptionId String? @db.ObjectId
  maxStudents           Int     @default(0)
  maxTeachers           Int     @default(0)
  maxAdmins             Int     @default(0)
  maxStorageInGB        Int     @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////
// USER
//////////////////////
model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  email    String @unique
  password String
  role     String

  tenantId String? @db.ObjectId
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  isFirstLogin   Boolean   @default(true)
  resetOtp       String?
  resetOtpExpiry DateTime?
  createdAt      DateTime  @default(now())

  @@map("User")
}

//////////////////////
// ACADEMIC YEAR
//////////////////////
model AcademicYear {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  enrollments   Enrollment[]
  classes       Class[]
  students      Student[]
  sections      Section[]
  subjects      Subject[]
  teachers      Teacher[]
  feeStructures FeeStructure[]
  attendances   Attendance[]
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
}

//////////////////////
// CLASS
//////////////////////
model Class {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  teachers        TeacherClass[]
  subjects        Subject[]
  sections        Section[]
  enrollments     Enrollment[]
  timetables      Timetable[]
  classAgeConfigs ClassAgeConfig[]
  feeStructures   FeeStructure[]

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
}

//////////////////////
// SECTION
//////////////////////
model Section {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  classId        String @db.ObjectId
  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  class        Class        @relation(fields: [classId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  enrollments Enrollment[]
  timetables  Timetable[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

//////////////////////
// STUDENT
//////////////////////
model Student {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  firstName   String
  lastName    String
  gender      String
  dob         DateTime
  bloodGroup  String?
  religion    String?
  caste       String?
  category    String?
  nationality String   @default("Indian")
  aadharNo    String?

  email   String?
  phone   String?
  address String

  admissionNo   String
  srNo          String?
  rollNumber    String?
  admissionDate DateTime @default(now())

  fatherName       String
  motherName       String
  fatherPhone      String
  motherPhone      String?
  fatherOccupation String?
  motherOccupation String?
  guardianName     String?
  guardianPhone    String?
  guardianRelation String?

  photoUrl    String?
  documents   StudentDocument[]

  status   String  @default("active")

  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  enrollments      Enrollment[]
  studentHistories StudentHistory[]
  promotions       Promotion[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([admissionNo, tenantId])
  @@index([srNo, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, academicYearId])
}

//////////////////////
// STUDENT DOCUMENT
//////////////////////
model StudentDocument {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  studentId String @db.ObjectId
  tenantId  String @db.ObjectId

  type     String
  name     String
  url      String
  mimeType String?
  size     Int?

  student Student @relation(fields: [studentId], references: [id])

  uploadedAt DateTime @default(now())
  isDeleted  Boolean  @default(false)

  @@index([studentId])
  @@index([tenantId, type])
}

//////////////////////
// ENROLLMENT
//////////////////////
model Enrollment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  studentId      String @db.ObjectId
  classId        String @db.ObjectId
  sectionId      String @db.ObjectId
  academicYearId String @db.ObjectId
  tenantId       String @db.ObjectId

  rollNumber String?
  status     String  @default("active")

  student      Student      @relation(fields: [studentId], references: [id])
  class        Class        @relation(fields: [classId], references: [id])
  section      Section      @relation(fields: [sectionId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])

  studentFees StudentFee[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@unique([studentId, academicYearId])
  @@index([classId, sectionId, academicYearId])
  @@index([tenantId, academicYearId])
}

//////////////////////
// STUDENT HISTORY
//////////////////////
model StudentHistory {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  studentId String @db.ObjectId
  tenantId  String @db.ObjectId

  action  String
  details String  @default("{}")
  message String?

  fromClassId    String?
  toClassId      String?
  fromSectionId  String?
  toSectionId    String?
  academicYearId String?

  performedBy String

  student Student @relation(fields: [studentId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([tenantId, action])
}

//////////////////////
// PROMOTION
//////////////////////
model Promotion {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  studentId String @db.ObjectId
  tenantId  String @db.ObjectId

  fromClassId        String
  fromSectionId      String
  fromAcademicYearId String

  toClassId        String
  toSectionId      String
  toAcademicYearId String

  type       String
  remarks    String?
  promotedBy String

  student Student @relation(fields: [studentId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  promotedAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  promotionType String

  @@index([tenantId, fromAcademicYearId])
  @@index([studentId])
}

//////////////////////
// ADMISSION COUNTER
//////////////////////
model AdmissionCounter {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId
  prefix         String @default("ADM")
  lastNumber     Int    @default(0)
  format         String @default("PREFIX/YEAR/SERIAL")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, academicYearId])
}

//////////////////////
// CLASS AGE CONFIG
//////////////////////
model ClassAgeConfig {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  tenantId  String    @db.ObjectId
  classId   String    @db.ObjectId
  board     BoardType
  className String
  minAge    Float
  maxAge    Float

  ageCalcRefMonth Int     @default(3)
  ageCalcRefDay   Int     @default(31)
  isActive        Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  class  Class  @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, classId, board])
  @@index([tenantId, board])
}

enum BoardType {
  UP_BOARD
  CBSE
  ICSE
  STATE_BOARD
  IB
  IGCSE
}

//////////////////////
// SUBJECT
//////////////////////
model Subject {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  classId        String @db.ObjectId
  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  class        Class        @relation(fields: [classId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  teachers   TeacherSubject[]
  timetables Timetable[]

  periodsPerWeek Int      @default(6)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
}

//////////////////////
// TEACHER
//////////////////////
model Teacher {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String
  email String @unique
  phone String

  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  subjects   TeacherSubject[]
  classes    TeacherClass[]
  timetables Timetable[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
}

//////////////////////
// TeacherSubject
//////////////////////
model TeacherSubject {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  teacherId String @db.ObjectId
  subjectId String @db.ObjectId

  teacher Teacher @relation(fields: [teacherId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

//////////////////////
// TeacherClass
//////////////////////
model TeacherClass {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  teacherId String @db.ObjectId
  classId   String @db.ObjectId

  teacher Teacher @relation(fields: [teacherId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

//////////////////////
// ATTENDANCE
//////////////////////
enum AttendanceStatus {
  PRESENT
  ABSENT
}

model Attendance {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId

  studentId      String   @db.ObjectId
  classId        String   @db.ObjectId
  sectionId      String   @db.ObjectId
  tenantId       String   @db.ObjectId

  academicYearId String   @db.ObjectId
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  date           DateTime
  status         AttendanceStatus

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  isDeleted      Boolean  @default(false)
  deletedAt      DateTime?

  @@index([studentId, date])
  @@index([classId, sectionId, date])
}

//////////////////////
// TIMETABLE
//////////////////////
enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

model Timetable {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  classId   String @db.ObjectId
  sectionId String @db.ObjectId
  subjectId String @db.ObjectId
  teacherId String @db.ObjectId
  tenantId  String @db.ObjectId

  day    DayOfWeek
  period Int

  class   Class   @relation(fields: [classId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([classId, sectionId, day, period])
}

//////////////////////
// EXAM
//////////////////////
model Exam {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  type            String?
  classId         String    @db.ObjectId
  sectionId       String?   @db.ObjectId
  academicYearId  String    @db.ObjectId
  tenantId        String    @db.ObjectId
  startDate       DateTime?
  endDate         DateTime?
  resultType      String    @default("BOTH")
  isPublished     Boolean   @default(false)
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─────────────── REPLACE your old ExamSubject model ───────────────
model ExamSubject {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  examId        String  @db.ObjectId
  subjectId     String  @db.ObjectId
  tenantId      String  @db.ObjectId
  maxMarks      Int
  passingMarks  Int
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
}

// ─────────────── NEW — Replace old Result model ───────────────
model MarksEntry {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  examId          String   @db.ObjectId
  studentId       String   @db.ObjectId
  subjectId       String   @db.ObjectId
  tenantId        String   @db.ObjectId
  marksObtained   Float
  isAbsent        Boolean  @default(false)
  isDeleted       Boolean  @default(false)
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────── NEW — Grade Settings ───────────────
model GradeSetting {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String  @db.ObjectId
  grade       String
  minPercent  Float
  maxPercent  Float
  gradePoint  Float?
  remarks     String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─────────────── NEW — Result Summary ───────────────
model ResultSummary {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  examId          String  @db.ObjectId
  studentId       String  @db.ObjectId
  tenantId        String  @db.ObjectId
  totalMarks      Float
  totalMaxMarks   Float
  percentage      Float
  grade           String?
  rank            Int?
  division        String?
  status          String
  totalSubjects   Int
  passedSubjects  Int
  failedSubjects  Int
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
// ═══════════════════════════════════════════════════════════════
// 💰 FEES MODULE (Dynamic — Admin-Defined)
// ═══════════════════════════════════════════════════════════════

//////////////////////
// FEE HEAD (Master — Admin defines fee types)
//////////////////////
model FeeHead {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String      @db.ObjectId
  name        String      // "Tuition Fee", "Lab Fee", "Transport Fee"
  code        String?     // Short code: "TF", "LF", "TR"
  description String?
  type        FeeHeadType @default(RECURRING)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  structureItems FeeStructureItem[]

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

enum FeeHeadType {
  RECURRING
  ONE_TIME
}

//////////////////////
// FEE STRUCTURE (Class + AcademicYear wise fee plan)
//////////////////////
model FeeStructure {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  tenantId        String          @db.ObjectId
  academicYearId  String          @db.ObjectId
  classId         String          @db.ObjectId

  name              String        // "Class 1 Fee 2025-26"
  totalAmount       Float         // Sum of all head amounts
  installmentType   InstallmentType @default(MONTHLY)
  totalInstallments Int           @default(12)
  dueDay            Int           @default(10) // Day of month fee is due

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  class        Class        @relation(fields: [classId], references: [id])

  items       FeeStructureItem[]
  studentFees StudentFee[]

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, classId, academicYearId])
  @@index([tenantId, academicYearId])
}

enum InstallmentType {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  ONE_TIME
  CUSTOM
}

//////////////////////
// FEE STRUCTURE ITEM (Head-wise breakdown)
//////////////////////
model FeeStructureItem {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  feeStructureId String @db.ObjectId
  feeHeadId      String @db.ObjectId

  amount    Float
  frequency String @default("PER_INSTALLMENT") // PER_INSTALLMENT or ONE_TIME

  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  feeHead      FeeHead      @relation(fields: [feeHeadId], references: [id])

  @@unique([feeStructureId, feeHeadId])
}

//////////////////////
// FEE DISCOUNT (Master — Discount types)
//////////////////////
model FeeDiscount {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String       @db.ObjectId
  name        String       // "Sibling Discount", "Merit Scholarship"
  type        DiscountType
  value       Float        // 10 = 10% or ₹10 based on type
  description String?

  applicableHeadIds String[] @db.ObjectId // Empty = all heads

  tenant Tenant @relation(fields: [tenantId], references: [id])

  studentFeeDiscounts StudentFeeDiscount[]

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

//////////////////////
// FINE RULE (Late payment penalty)
//////////////////////
model FineRule {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  tenantId     String @db.ObjectId
  name         String
  afterDays    Int    // Fine starts X days after due
  amountPerDay Float  // ₹/day
  maxAmount    Float  // Cap

  tenant Tenant @relation(fields: [tenantId], references: [id])

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId])
}

//////////////////////
// STUDENT FEE (Assigned per student per installment)
//////////////////////
model StudentFee {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  tenantId       String @db.ObjectId
  enrollmentId   String @db.ObjectId
  feeStructureId String @db.ObjectId

  totalAmount    Float
  discountAmount Float     @default(0)
  fineAmount     Float     @default(0)
  netAmount      Float
  paidAmount     Float     @default(0)
  balanceAmount  Float

  installmentNo  Int
  dueDate        DateTime
  status         FeeStatus @default(PENDING)

  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id])
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])

  payments  Payment[]
  discounts StudentFeeDiscount[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([enrollmentId, feeStructureId, installmentNo])
  @@index([tenantId, status])
  @@index([enrollmentId])
  @@index([tenantId, dueDate])
}

enum FeeStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

//////////////////////
// STUDENT FEE DISCOUNT (Applied discounts)
//////////////////////
model StudentFeeDiscount {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  studentFeeId  String @db.ObjectId
  feeDiscountId String @db.ObjectId
  amount        Float

  studentFee  StudentFee  @relation(fields: [studentFeeId], references: [id])
  feeDiscount FeeDiscount @relation(fields: [feeDiscountId], references: [id])

  createdAt DateTime @default(now())

  @@unique([studentFeeId, feeDiscountId])
}

//////////////////////
// PAYMENT (Fee collection records)
//////////////////////
model Payment {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  tenantId     String        @db.ObjectId
  studentFeeId String        @db.ObjectId

  amount       Float
  method       PaymentMethod
  reference    String?       // Txn ID, Cheque No, UPI ref
  remarks      String?

  receiptNo    String        @unique
  paymentDate  DateTime      @default(now())
  collectedBy  String?       @db.ObjectId

  studentFee StudentFee @relation(fields: [studentFeeId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId])
  @@index([studentFeeId])
  @@index([tenantId, paymentDate])

}

enum PaymentMethod {
  CASH
  ONLINE
  UPI
  CHEQUE
  BANK_TRANSFER
  DD
}

// ═══════════════════════════════════════════════════════════════
// END FEES MODULE
// ═══════════════════════════════════════════════════════════════

//////////////////////
// AUDIT LOG
//////////////////////
model AuditLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  action   String
  entity   String
  entityId String
  userId   String?
  data     Json?

  createdAt DateTime @default(now())
}

//////////////////////
// SUBSCRIPTION PLAN
//////////////////////
model SubscriptionPlan {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name           String
  slug           String  @unique
  description    String?
  price          Float
  durationInDays Int
  currency       String  @default("INR")

  maxStudents    Int
  maxTeachers    Int
  maxAdmins      Int @default(1)
  maxStorageInGB Int @default(5)

  features String[]

  isTrial   Boolean @default(false)
  isPopular Boolean @default(false)
  isActive  Boolean @default(true)

  subscriptions TenantSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

//////////////////////
// TENANT SUBSCRIPTION
//////////////////////
model TenantSubscription {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  subscriptionCode String @unique

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  planId String           @db.ObjectId
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  payments SubscriptionPayment[]

  startDate   DateTime
  endDate     DateTime
  trialEndsAt DateTime?
  cancelledAt DateTime?

  status   SubscriptionStatus @default(PENDING)
  isActive Boolean            @default(false)

  amount           Float
  currency         String        @default("INR")
  paymentStatus    PaymentStatus @default(PENDING)
  paymentReference String?
  paymentGateway   String?

  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  invoiceNumber  String?
  autoRenew      Boolean @default(false)
  maxStudents    Int
  maxTeachers    Int
  maxAdmins      Int
  maxStorageInGB Int
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@index([paymentStatus])
  @@index([startDate])
  @@index([endDate])
  @@index([isActive])
  @@index([createdAt])
}

//////////////////////
// SUBSCRIPTION PAYMENT
//////////////////////
model SubscriptionPayment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  subscriptionId String             @db.ObjectId
  subscription   TenantSubscription @relation(fields: [subscriptionId], references: [id])

  amount   Float
  currency String @default("INR")
  method   String?
  gateway  String?

  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  status PaymentStatus @default(PENDING)

  notes      String?
  paidAt     DateTime?
  refundedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionId])
  @@index([status])
  @@index([createdAt])
}

//////////////////////
// ENUMS
//////////////////////
enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  TRIAL
  CANCELLED
  SUSPENDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

//////////////////////
// PLATFORM SETTINGS
//////////////////////
model PlatformSettings {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  appName      String   @default("College ERP")
  tagline      String?
  primaryColor String   @default("#4f46e5")
  logoUrl      String?
  faviconUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}