  name     String   // Display name: "All Students", "Fee Collection"
  moduleId String   // Reference to ModuleMaster code
  route    String   // Frontend route
  icon     String   // Lucide icon name
  order    Int      @default(0)
  parentId String?  @db.ObjectId // For nested menu items

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model APIPermissionMaster {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
