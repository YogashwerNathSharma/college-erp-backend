{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "composite": true
  },
  "references": [
    { "path": "./backend" },
    { "path": "./frontend" },
    { "path": "./student-portal" },
    { "path": "./shared" }
  ],
  "exclude": ["node_modules", "**/node_modules", "**/dist"]
}
