// ══════════════════════════════════════════════════════════════════════════════
// TENANT MODEL ADDITIONS
// Add these relation arrays to the existing Tenant model in schema.prisma:
// ══════════════════════════════════════════════════════════════════════════════
//
// // Fee Masters
// feeGroupMasters        FeeGroupMaster[]
// feeTypeMasters         FeeTypeMaster[]
// concessionMasters      ConcessionMaster[]
// scholarshipMasters     ScholarshipMaster[]
// paymentModeMasters     PaymentModeMaster[]
// receiptSeriesMasters   ReceiptSeriesMaster[]
//
// // Examination Masters
// examTypeMasters        ExamTypeMaster[]
// examTermMasters        ExamTermMaster[]
// resultTypeMasters      ResultTypeMaster[]
// markingSchemeMasters   MarkingSchemeMaster[]
// assessmentMasters      AssessmentMaster[]
//
// // Attendance Masters
// attendanceStatusMasters  AttendanceStatusMaster[]
// lateFineMasters          LateFineMaster[]
// leaveReasonMasters       LeaveReasonMaster[]
// attendanceShiftMasters   AttendanceShiftMaster[]
//
// // Library Masters
// publisherMasters       PublisherMaster[]
// authorMasters          AuthorMaster[]
// languageMasters        LanguageMaster[]
// rackMasters            RackMaster[]
// shelfMasters           ShelfMaster[]
// bookConditionMasters   BookConditionMaster[]
//
// // Hostel Masters
// blockMasters           BlockMaster[]
// floorMasters           FloorMaster[]
// bedMasters             BedMaster[]
// hostelTypeMasters      HostelTypeMaster[]
//
// // Transport Masters
// driverMasters          DriverMaster[]
// conductorMasters       ConductorMaster[]
// fuelTypeMasters        FuelTypeMaster[]
// gpsDeviceMasters       GPSDeviceMaster[]
//
// // Inventory Masters
// itemCategoryMasters    ItemCategoryMaster[]
// itemGroupMasters       ItemGroupMaster[]
// unitMasters            UnitMaster[]
// brandMasters           BrandMaster[]
// supplierMasters        SupplierMaster[]
// warehouseMasters       WarehouseMaster[]
// storeMasters           StoreMaster[]
