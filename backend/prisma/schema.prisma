//////////////////////
// USER
//////////////////////
model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  email    String @unique
  password String
  role     String
  phone    String?          
  status   String  @default("ACTIVE")  
  tenantId String? @db.ObjectId
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
freeTrialRecords FreeTrialRecord[]
  isFirstLogin   Boolean   @default(true)
  resetOtp       String?
  resetOtpExpiry DateTime?
  createdAt      DateTime  @default(now())

  // Enterprise back-relations
  sessions          Session[]
  reportedTickets   SupportTicket[] @relation("TicketReporter")
  assignedTickets   SupportTicket[] @relation("TicketAssignee")
  kbArticles        KbArticle[]     @relation("KBAuthor")

  @@map("User")
}

// ══════════════════════════════════
// ACADEMIC YEAR (Fixed)
// ══════════════════════════════════
model AcademicYear {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  startDate DateTime
  endDate   DateTime

  isActive  Boolean @default(false)
  isCurrent Boolean @default(false)

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Core Relations
  classes     Class[]
  sections    Section[]
  subjects    Subject[]
  students    Student[]
  teachers    Teacher[]
  enrollments Enrollment[]

  // Fee Module
  feeStructures FeeStructure[]

  // Teacher Module
  teacherLeaves       TeacherLeave[]
  teacherSalaries     TeacherSalary[]
  teacherPerformances TeacherPerformance[]
  teacherSettings     TeacherSettings[]

  // Student Module
  admissionCounters AdmissionCounter[]

  // Attendance
  attendances Attendance[]

  // Exam Module
  exams              Exam[]
  examResults        ExamResult[]
  examTermMasters    ExamTermMaster[]
  hostelAllocations  HostelAllocation[]
  studentHistories   StudentHistory[]

  // Soft Delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////
// CLASS
//////////////////////
model Class {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  teachers        TeacherClass[]
  subjects        Subject[]
  sections        Section[]
  enrollments     Enrollment[]
  timetables      Timetable[]
  classAgeConfigs ClassAgeConfig[]
  feeStructures   FeeStructure[]

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
}

//////////////////////
// SECTION
//////////////////////
model Section {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  classId        String @db.ObjectId
  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  class        Class        @relation(fields: [classId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  enrollments Enrollment[]
  timetables  Timetable[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

//////////////////////
// STUDENT
//////////////////////

model Student {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  firstName String
  lastName  String
  fullName  String?
  gender    String
  dob       DateTime

  bloodGroup String?
  religion   String?
  caste      String?
  category   String?

  nationality String @default("Indian")

  aadharNo String?
  email    String?
  phone    String?

  address String

  admissionNo String
  srNo        String?
  rollNumber  String?

  admissionDate DateTime @default(now())

  fatherName       String
  motherName       String
  fatherPhone      String
  motherPhone      String?
  fatherOccupation String?
  motherOccupation String?

  guardianName     String?
  guardianPhone    String?
  guardianRelation String?

  photoUrl String?

  // Relations
  documents        StudentDocument[]
  enrollments      Enrollment[]
  studentHistories StudentHistory[]
  attendance       Attendance[]
  promotions       Promotion[]

  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  status String @default("active")

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  transferCertificates   TransferCertificate[]
  characterCertificates  CharacterCertificate[]
  migrationCertificates  MigrationCertificate[]
  seatingArrangements    SeatingArrangement[]
  admitCards             AdmitCard[]
  resultSummaries        ResultSummary[]

  // ── Medical History ──
  medicalConditions  String[]
  allergies          String[]
  medications        String[]
  emergencyContact   String?
  emergencyPhone     String?
  insuranceId        String?
  lastMedicalCheckup DateTime?

  // ── Identification ──
  rfidCardNo         String?
  qrCode             String?
  biometricId        String?
  previousSchool     String?
  previousClass      String?

  // ── Custom & Extended ──
  customFields       Json?

  // ── Extended Relations ──
  achievements        StudentAchievement[]
  disciplinaryRecords StudentDisciplinaryRecord[]
  timeline            StudentTimelineEntry[]

  @@unique([admissionNo, tenantId])
  @@index([srNo, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, academicYearId])
}

//////////////////////
// STUDENT DOCUMENT
//////////////////////
model StudentDocument {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  studentId String @db.ObjectId
  tenantId  String @db.ObjectId

  type String
  name String
  url  String

  mimeType String?
  size     Int?

  student Student @relation(fields: [studentId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  uploadedAt DateTime @default(now())

  isDeleted Boolean @default(false)

  @@index([studentId])
  @@index([tenantId, type])
}

//////////////////////
// ENROLLMENT
//////////////////////
model Enrollment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  studentId      String @db.ObjectId
  classId        String @db.ObjectId
  sectionId      String @db.ObjectId
  academicYearId String @db.ObjectId
  tenantId       String @db.ObjectId

  rollNumber String?
  status     String @default("active")

  student      Student      @relation(fields: [studentId], references: [id])
  class        Class        @relation(fields: [classId], references: [id])
  section      Section      @relation(fields: [sectionId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])

  studentFees StudentFee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@unique([studentId, academicYearId])
  @@index([classId, sectionId, academicYearId])
  @@index([tenantId, academicYearId])
}

//////////////////////
// STUDENT HISTORY
//////////////////////
model StudentHistory {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  studentId String @db.ObjectId
  tenantId  String @db.ObjectId

  action  String
  details String @default("{}")
  message String?

  fromClassId   String?
  toClassId     String?
  fromSectionId String?
  toSectionId   String?

  academicYearId String?       @db.ObjectId
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])

  performedBy String

  student Student @relation(fields: [studentId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([tenantId, action])
}

model Promotion {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  studentId String @db.ObjectId
  tenantId  String @db.ObjectId

  fromClassId        String
  fromSectionId      String
  fromAcademicYearId String

  toClassId          String
  toSectionId        String
  toAcademicYearId   String

  promotionType String
  type          String

  remarks String?

  promotedBy String

  student Student @relation(fields: [studentId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  promotedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([tenantId, fromAcademicYearId])
  @@index([studentId])
}

//////////////////////
// ADMISSION COUNTER
//////////////////////
model AdmissionCounter {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  prefix String @default("ADM")

  lastNumber Int @default(0)

  format String @default("PREFIX/YEAR/SERIAL")
  academicYear AcademicYear @relation(fields: [academicYearId],references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, academicYearId])
}
//////////////////////
// CLASS AGE CONFIG
//////////////////////
model ClassAgeConfig {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  tenantId String @db.ObjectId
  classId  String @db.ObjectId

  board BoardType

  className String

  minAge Float
  maxAge Float

  ageCalcRefMonth Int @default(3)
  ageCalcRefDay   Int @default(31)

  isActive Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  class  Class  @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, classId, board])
  @@index([tenantId, board])
}

enum BoardType {
  UP_BOARD
  CBSE
  ICSE
  STATE_BOARD
  IB
  IGCSE
}

//////////////////////
// SUBJECT
//////////////////////
model Subject {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  classId        String @db.ObjectId
  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  class        Class        @relation(fields: [classId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  teachers   TeacherSubject[]
  timetables Timetable[]
  examSchedules          ExamSchedule[]
  questionPapers         QuestionPaper[]
  examResults            ExamResult[]
  periodsPerWeek Int      @default(6)
  isActive       Boolean  @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt      DateTime @default(now())
}

//////////////////////
// TEACHER
//////////////////////

model Teacher {
  id    String @id @default(auto()) @map("_id") @db.ObjectId

  // Basic Information
  firstName String
  lastName  String
  name      String // Auto: firstName + " " + lastName

  email String @unique
  phone String

  // Personal Information
  gender        String? // Male | Female | Other
  dob           DateTime?
  employeeId    String? // TCH001
  maritalStatus String? // Single | Married | Divorced | Widowed
  photoUrl      String?

  // Multi-Tenant Fields
  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  // Relations
  subjects      TeacherSubject[]
  classes       TeacherClass[]
  timetables    Timetable[]

  leaves        TeacherLeave[]
  salaries      TeacherSalary[]
  performances  TeacherPerformance[]
  documents     TeacherDocument[]
  invigilatorAssignments InvigilatorAssignment[]
  // Soft Delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Audit
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([academicYearId])
  @@index([employeeId])
}

//////////////////////
// TeacherSubject
//////////////////////
model TeacherSubject {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  teacherId String @db.ObjectId
  subjectId String @db.ObjectId

  teacher Teacher @relation(fields: [teacherId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

//////////////////////
// TeacherClass
//////////////////////
model TeacherClass {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  teacherId String @db.ObjectId
  classId   String @db.ObjectId

  teacher Teacher @relation(fields: [teacherId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

//////////////////////
// ATTENDANCE
//////////////////////
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model Attendance {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId

  studentId      String   @db.ObjectId
  classId        String   @db.ObjectId
  sectionId      String   @db.ObjectId
  student        Student  @relation(fields: [studentId], references: [id])
  tenantId       String   @db.ObjectId
  tenant Tenant  @relation(fields: [tenantId], references: [id])
  academicYearId String   @db.ObjectId
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  date           DateTime
  status         AttendanceStatus

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  isDeleted      Boolean  @default(false)
  deletedAt      DateTime?

  @@index([studentId, date])
  @@index([classId, sectionId, date])
}
// ======================
// ENUMS
// ======================

enum LeaveType {
  CASUAL
  MEDICAL
  EARNED
  MATERNITY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SalaryStatus {
  PENDING
  PAID
}

enum DocumentType {
  PERSONAL
  IDENTITY
  ACADEMIC
  EXPERIENCE
}

enum SenderType {
  ADMIN
  PRINCIPAL
  SYSTEM
}

// ======================
// TEACHER LEAVE
// ======================

model TeacherLeave {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  teacherId      String        @db.ObjectId
  leaveType      LeaveType
  fromDate       DateTime
  toDate         DateTime
  days           Int
  reason         String
  status         LeaveStatus   @default(PENDING)
  approvedBy     String?       @db.ObjectId
  tenantId       String        @db.ObjectId
  academicYearId String        @db.ObjectId

  teacher        Teacher       @relation(fields: [teacherId], references: [id])
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id])

  isDeleted      Boolean       @default(false)
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([teacherId, status])
  @@index([tenantId, academicYearId])
}

// ======================
// TEACHER SALARY
// ======================

model TeacherSalary {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  teacherId        String        @db.ObjectId
  month            Int
  year             Int

  basicSalary      Float

  allowances       Json
  deductions       Json

  totalAllowances  Float
  totalDeductions  Float
  netSalary        Float

  status           SalaryStatus @default(PENDING)
  paidAt           DateTime?

  tenantId         String        @db.ObjectId
  academicYearId   String        @db.ObjectId

  teacher          Teacher       @relation(fields: [teacherId], references: [id])
  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  academicYear     AcademicYear  @relation(fields: [academicYearId], references: [id])

  isDeleted        Boolean       @default(false)
  deletedAt        DateTime?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([teacherId, month, year])
  @@index([tenantId, academicYearId])
}

// ======================
// TEACHER PERFORMANCE
// ======================

model TeacherPerformance {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  teacherId        String        @db.ObjectId
  academicYearId   String        @db.ObjectId
  tenantId         String        @db.ObjectId

  parameters       Json
  overallRating    Float
  remarks          String?

  evaluatedBy      String?       @db.ObjectId

  teacher          Teacher       @relation(fields: [teacherId], references: [id])
  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  academicYear     AcademicYear  @relation(fields: [academicYearId], references: [id])

  isDeleted        Boolean       @default(false)
  deletedAt        DateTime?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([teacherId, academicYearId])
}

// ======================
// TEACHER DOCUMENT
// ======================

model TeacherDocument {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  teacherId     String       @db.ObjectId

  name          String
  type          DocumentType
  fileUrl       String

  uploadDate    DateTime     @default(now())

  tenantId      String       @db.ObjectId

  teacher       Teacher      @relation(fields: [teacherId], references: [id])
  tenant        Tenant       @relation(fields: [tenantId], references: [id])

  isDeleted     Boolean      @default(false)
  deletedAt     DateTime?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// ======================
// COMMUNICATION
// ======================

model Communication {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId

  title         String
  message       String

  senderType    SenderType
  senderName    String

  tenantId      String       @db.ObjectId

  tenant        Tenant       @relation(fields: [tenantId], references: [id])

  isDeleted     Boolean      @default(false)
