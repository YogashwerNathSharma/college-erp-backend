// ======================
// TEACHER SETTINGS
// ======================

model TeacherSettings {
  id                     String        @id @default(auto()) @map("_id") @db.ObjectId

  tenantId               String        @unique @db.ObjectId
  academicYearId         String        @db.ObjectId

  // General Settings
  dateFormat             String        @default("DD/MM/YYYY")
  timeFormat             String        @default("24 Hour")

  // Attendance Settings
  attendanceRequired     Boolean       @default(true)
  lateMarkTime           String        @default("09:30")
  halfDayTime            String        @default("13:00")

  // Leave Settings
  casualLeavePerYear     Int           @default(12)
  medicalLeavePerYear    Int           @default(10)
  earnedLeavePerYear     Int           @default(15)

  // Salary Settings
  payDay                 Int           @default(1)
  salarySlipTemplate     String        @default("default")

  // Notification Settings
  emailNotifications     Boolean       @default(true)
  smsNotifications       Boolean       @default(false)

  tenant                Tenant         @relation(fields: [tenantId], references: [id])
  academicYear          AcademicYear   @relation(fields: [academicYearId], references: [id])

  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

//////////////////////
// TIMETABLE
//////////////////////
enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

model Timetable {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  classId   String @db.ObjectId
  sectionId String @db.ObjectId
  subjectId String @db.ObjectId
  teacherId String @db.ObjectId
  tenantId  String @db.ObjectId

  day    DayOfWeek
  period Int

  class   Class   @relation(fields: [classId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([classId, sectionId, day, period])
}

