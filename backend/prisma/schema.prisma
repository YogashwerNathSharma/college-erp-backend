generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//////////////////////
// TENANT
//////////////////////
model Tenant {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  //////////////////////////////////////////////////
  // BASIC INFO
  //////////////////////////////////////////////////

  name String

  type String

  logoUrl String?

  backgroundUrl String?

  //////////////////////////////////////////////////
  // USERS
  //////////////////////////////////////////////////

  users User[]

  //////////////////////////////////////////////////
  // ACADEMICS
  //////////////////////////////////////////////////

  academicYears AcademicYear[]

  classes Class[]

  sections Section[]

  students Student[]

  subjects Subject[]

  teachers Teacher[]

  timetables Timetable[]

  enrollments Enrollment[]

  studentHistories StudentHistory[]

  //////////////////////////////////////////////////
  // PAYMENTS
  //////////////////////////////////////////////////

  payments Payment[]

  //////////////////////////////////////////////////
  // SUBSCRIPTIONS
  //////////////////////////////////////////////////

  subscriptions TenantSubscription[]

  //////////////////////////////////////////////////
  // CURRENT ACTIVE SUBSCRIPTION
  //////////////////////////////////////////////////

  currentSubscriptionId String? @db.ObjectId


  //////////////////////////////////////////////////
  // SUBSCRIPTION LIMITS
  //////////////////////////////////////////////////

  maxStudents Int @default(0)

  maxTeachers Int @default(0)

  maxAdmins Int @default(0)

  maxStorageInGB Int @default(0)

  //////////////////////////////////////////////////
  // STATUS
  //////////////////////////////////////////////////

  isActive Boolean @default(true)

  //////////////////////////////////////////////////
  // TIMESTAMPS
  //////////////////////////////////////////////////

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

//////////////////////
// USER
//////////////////////
model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  email    String @unique
  password String
  role     String

  tenantId String? @db.ObjectId
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  isFirstLogin Boolean @default(true)

  resetOtp       String?
  resetOtpExpiry DateTime?

  createdAt DateTime @default(now())

  @@map("User")
}

//////////////////////
// ACADEMIC YEAR
//////////////////////
model AcademicYear {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  enrollments Enrollment[]
  classes     Class[]
  students    Student[]
  sections    Section[]
  subjects    Subject[]
  teachers    Teacher[]

  createdAt DateTime @default(now())
}

//////////////////////
// CLASS
//////////////////////
model Class {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  teachers    TeacherClass[]
  subjects    Subject[]
  sections    Section[]
  enrollments Enrollment[]
  timetables  Timetable[]

  createdAt DateTime @default(now())
}

//////////////////////
// SECTION
//////////////////////
model Section {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  classId        String @db.ObjectId
  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  class        Class        @relation(fields: [classId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  enrollments Enrollment[]
  timetables  Timetable[]

  createdAt DateTime @default(now())
}

//////////////////////
// STUDENT
//////////////////////
model Student {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  firstName String
  lastName  String
  gender    String
  dob       DateTime

  email   String
  phone   String
  address String

  admissionNo String
  rollNumber  String?

  fatherName  String
  motherName  String
  parentPhone String

  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  enrollments      Enrollment[]
  studentHistories StudentHistory[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, tenantId])
  @@unique([admissionNo, tenantId])
}

//////////////////////
// SUBJECT
//////////////////////
model Subject {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  classId        String @db.ObjectId
  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  class        Class        @relation(fields: [classId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  teachers   TeacherSubject[]
  timetables Timetable[]

  createdAt DateTime @default(now())
}

//////////////////////
// TEACHER
//////////////////////
model Teacher {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name  String
  email String @unique
  phone String

  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  subjects   TeacherSubject[]
  classes    TeacherClass[]
  timetables Timetable[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
}

//////////////////////
// TeacherSubject
//////////////////////
model TeacherSubject {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  teacherId String @db.ObjectId
  subjectId String @db.ObjectId

  teacher Teacher @relation(fields: [teacherId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

//////////////////////
// TeacherClass
//////////////////////
model TeacherClass {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  teacherId String @db.ObjectId
  classId   String @db.ObjectId

  teacher Teacher @relation(fields: [teacherId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

//////////////////////
// ATTENDANCE
//////////////////////
enum AttendanceStatus {
  PRESENT
  ABSENT
}

model Attendance {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  studentId String @db.ObjectId
  classId   String @db.ObjectId
  sectionId String @db.ObjectId
  tenantId  String @db.ObjectId

  date   DateTime
  status AttendanceStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([studentId, date])
}

//////////////////////
// TIMETABLE
//////////////////////
enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

model Timetable {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  classId   String @db.ObjectId
  sectionId String @db.ObjectId
  subjectId String @db.ObjectId
  teacherId String @db.ObjectId
  tenantId  String @db.ObjectId

  day    DayOfWeek
  period Int

  class   Class   @relation(fields: [classId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classId, sectionId, day, period])
}

//////////////////////
// EXAM
//////////////////////
model Exam {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  type     String?
  classId  String  @db.ObjectId
  tenantId String  @db.ObjectId

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
}

model ExamSubject {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  examId    String @db.ObjectId
  subjectId String @db.ObjectId
  maxMarks  Int

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

model Result {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  studentId     String @db.ObjectId
  examId        String @db.ObjectId
  subjectId     String @db.ObjectId
  marksObtained Float
  tenantId      String @db.ObjectId

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

//////////////////////
// FEE STRUCTURE
//////////////////////
model FeeStructure {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId
  classId        String @db.ObjectId

  name      String
  amount    Float
  frequency String

  studentFees StudentFee[]

  createdAt DateTime @default(now())

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

//////////////////////
// ENROLLMENT
//////////////////////
model Enrollment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  studentId      String @db.ObjectId
  classId        String @db.ObjectId
  sectionId      String @db.ObjectId
  academicYearId String @db.ObjectId
  tenantId       String @db.ObjectId

  student      Student      @relation(fields: [studentId], references: [id])
  class        Class        @relation(fields: [classId], references: [id])
  section      Section      @relation(fields: [sectionId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])

  studentFees StudentFee[]

  createdAt DateTime @default(now())

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@unique([studentId, academicYearId])
}

//////////////////////
// STUDENT FEE
//////////////////////
model StudentFee {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  enrollmentId   String @db.ObjectId
  feeStructureId String @db.ObjectId
  tenantId       String @db.ObjectId

  totalAmount   Float
  paidAmount    Float  @default(0)
  pendingAmount Float
  status        String

  dueDate DateTime

  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id])
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])

  payments Payment[]

  createdAt DateTime @default(now())

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

//////////////////////
// PAYMENT
//////////////////////
enum PaymentMethod {
  CASH
  ONLINE
}

model Payment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  studentFeeId String     @db.ObjectId
  studentFee   StudentFee @relation(fields: [studentFeeId], references: [id])

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  amount    Float
  method    PaymentMethod
  reference String?

  receiptNo   String   @unique
  paymentDate DateTime @default(now())
  createdAt   DateTime @default(now())

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([tenantId])
  @@index([studentFeeId])
}

//////////////////////
// AUDIT LOG
//////////////////////
model AuditLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  action   String
  entity   String
  entityId String

  userId String?
  data   Json?

  createdAt DateTime @default(now())
}

//////////////////////
// STUDENT HISTORY
//////////////////////
model StudentHistory {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  studentId String @db.ObjectId
  tenantId  String @db.ObjectId

  action  String
  message String

  performedBy String

  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  @@index([studentId])
}

//////////////////////////////////////////////////////
// SUBSCRIPTION PLAN
//////////////////////////////////////////////////////

model SubscriptionPlan {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  //////////////////////////////////////////////////
  // BASIC INFO
  //////////////////////////////////////////////////

  name        String
  slug        String @unique
  description String?

  //////////////////////////////////////////////////
  // PRICING
  //////////////////////////////////////////////////

  price          Float
  durationInDays Int

  currency String @default("INR")

  //////////////////////////////////////////////////
  // LIMITS
  //////////////////////////////////////////////////

  maxStudents    Int
  maxTeachers    Int
  maxAdmins      Int @default(1)

  maxStorageInGB Int @default(5)

  //////////////////////////////////////////////////
  // FEATURES
  //////////////////////////////////////////////////

  features String[]

  //////////////////////////////////////////////////
  // FLAGS
  //////////////////////////////////////////////////

  isTrial   Boolean @default(false)
  isPopular Boolean @default(false)
  isActive  Boolean @default(true)

  //////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////

  subscriptions TenantSubscription[]

  //////////////////////////////////////////////////
  // TIMESTAMPS
  //////////////////////////////////////////////////

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //////////////////////////////////////////////////
  // INDEXES
  //////////////////////////////////////////////////

  @@index([isActive])
}

//////////////////////////////////////////////////////
// TENANT SUBSCRIPTION
//////////////////////////////////////////////////////

model TenantSubscription {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  //////////////////////////////////////////////////
  // SUBSCRIPTION CODE
  //////////////////////////////////////////////////

  subscriptionCode String @unique

  //////////////////////////////////////////////////
  // TENANT RELATION
  //////////////////////////////////////////////////

  tenantId String @db.ObjectId

  tenant Tenant @relation(fields: [tenantId],references: [id] )

  //////////////////////////////////////////////////
  // ACTIVE TENANT RELATION
  //////////////////////////////////////////////////

  //////////////////////////////////////////////////
  // PLAN RELATION
  //////////////////////////////////////////////////

  planId String @db.ObjectId

  plan SubscriptionPlan @relation(fields: [planId],references: [id] )

  payments SubscriptionPayment[]

  //////////////////////////////////////////////////
  // SUBSCRIPTION DATES
  //////////////////////////////////////////////////

  startDate DateTime

  endDate DateTime

  trialEndsAt DateTime?

  cancelledAt DateTime?

  //////////////////////////////////////////////////
  // SUBSCRIPTION STATUS
  //////////////////////////////////////////////////

  status SubscriptionStatus @default(PENDING)

  isActive Boolean @default(false)

  //////////////////////////////////////////////////
  // PAYMENT INFO
  //////////////////////////////////////////////////

  amount Float

  currency String @default("INR")

  paymentStatus PaymentStatus @default(PENDING)

  paymentReference String?

  paymentGateway String?

  //////////////////////////////////////////////////
  // RAZORPAY DETAILS
  //////////////////////////////////////////////////

  razorpayOrderId String?

  razorpayPaymentId String?

  razorpaySignature String?

  //////////////////////////////////////////////////
  // BILLING
  //////////////////////////////////////////////////

  invoiceNumber String?

  autoRenew Boolean @default(false)

  //////////////////////////////////////////////////
  // SNAPSHOT LIMITS
  //////////////////////////////////////////////////

  maxStudents Int

  maxTeachers Int

  maxAdmins Int

  maxStorageInGB Int

  //////////////////////////////////////////////////
  // EXTRA
  //////////////////////////////////////////////////

  notes String?

  //////////////////////////////////////////////////
  // TIMESTAMPS
  //////////////////////////////////////////////////

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  //////////////////////////////////////////////////
  // INDEXES
  //////////////////////////////////////////////////

  @@index([tenantId])

  @@index([planId])

  @@index([status])

  @@index([paymentStatus])

  @@index([startDate])

  @@index([endDate])

  @@index([isActive])

  @@index([createdAt])
}
//////////////////////////////////////////////////////
// PAYMENT TABLE
//////////////////////////////////////////////////////

model SubscriptionPayment{
  id String @id @default(auto()) @map("_id") @db.ObjectId

  //////////////////////////////////////////////////
  // RELATION
  //////////////////////////////////////////////////
subscriptionId String @db.ObjectId

subscription TenantSubscription @relation(fields: [subscriptionId], references: [id])
  //////////////////////////////////////////////////
  // PAYMENT INFO
  //////////////////////////////////////////////////

  amount Float

  currency String @default("INR")

  method String?

  gateway String?

  //////////////////////////////////////////////////
  // RAZORPAY
  //////////////////////////////////////////////////

  razorpayOrderId String?

  razorpayPaymentId String?

  razorpaySignature String?

  //////////////////////////////////////////////////
  // STATUS
  //////////////////////////////////////////////////

  status PaymentStatus @default(PENDING)

  //////////////////////////////////////////////////
  // EXTRA
  //////////////////////////////////////////////////

  notes String?

  paidAt DateTime?

  refundedAt DateTime?

  //////////////////////////////////////////////////
  // TIMESTAMPS
  //////////////////////////////////////////////////

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  //////////////////////////////////////////////////
  // INDEXES
  //////////////////////////////////////////////////

  @@index([subscriptionId])

  @@index([status])

  @@index([createdAt])
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  TRIAL
  CANCELLED
  SUSPENDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}
model PlatformSettings {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  appName      String   @default("College ERP")
  tagline      String?
  primaryColor String   @default("#4f46e5")
  logoUrl      String?
  faviconUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}