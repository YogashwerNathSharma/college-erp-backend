// ======================================================
// TRANSPORT MODULE
// Prisma Version : 6.19.3
// Database : MongoDB
// ======================================================

enum VehicleType {
  BUS
  VAN
  AUTO
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum RouteStatus {
  ACTIVE
  INACTIVE
}

enum AssignmentType {
  PICKUP
  DROP
  BOTH
}

enum AssignmentStatus {
  ACTIVE
  INACTIVE
}

enum AttendanceType {
  PICKUP
  DROP
}

enum FuelType {
  DIESEL
  PETROL
  CNG
  ELECTRIC
}

model Vehicle {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId

  vehicleNo         String
  type              VehicleType

  capacity          Int

  driverName        String
  driverPhone       String
  driverLicense     String

  conductorName     String?
  conductorPhone    String?

  insuranceExpiry   DateTime
  fitnessExpiry     DateTime
  permitExpiry      DateTime

  fuelType          FuelType

  status            VehicleStatus @default(ACTIVE)

  tenantId          String @db.ObjectId
  tenant            Tenant @relation(fields: [tenantId], references: [id])

  assignments       TransportAssignment[]
  locations         VehicleLocation[]
  tripLogs          TripLog[]
  geofenceAlerts    GeofenceAlert[]
  transportTrips    TransportTrip[]
  transportAlerts   TransportAlert[]
  transportPickupDrops TransportPickupDrop[]

  // Online Tracking Fields
  currentLatitude      Float?
  currentLongitude     Float?
  lastLocationUpdate   DateTime?
  isOnline             Boolean @default(false)

  isDeleted         Boolean @default(false)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@index([vehicleNo])
}

model Route {

  id                String @id @default(auto()) @map("_id") @db.ObjectId

  name              String
  code              String

  startLocation     String
  endLocation       String

  distance          Float

  estimatedTime     Int

  monthlyFee        Float

  status            RouteStatus @default(ACTIVE)

  tenantId          String @db.ObjectId
  tenant            Tenant @relation(fields: [tenantId], references: [id])

  stops             RouteStop[]

  assignments       TransportAssignment[]
  transportTrips    TransportTrip[]

  isDeleted         Boolean @default(false)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@index([code])
}

model RouteStop {

  id              String @id @default(auto()) @map("_id") @db.ObjectId

  routeId         String @db.ObjectId
  route           Route @relation(fields: [routeId], references: [id])

  name            String

  pickupTime      String
  dropTime        String

  sequence        Int

  latitude        Float?
  longitude       Float?

  tenantId        String @db.ObjectId
  tenant          Tenant @relation(fields: [tenantId], references: [id])

  assignments     TransportAssignment[]

  isDeleted       Boolean @default(false)

  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([routeId])
}

model TransportAssignment {

  id                String @id @default(auto()) @map("_id") @db.ObjectId

  studentId         String
  studentName       String
  classInfo         String

  routeId           String @db.ObjectId
  route             Route @relation(fields: [routeId], references: [id])

  stopId    String?    @db.ObjectId       // ? add karo
  stop      RouteStop? @relation(fields: [stopId], references: [id])   // ? add karo

  vehicleId         String @db.ObjectId
  vehicle           Vehicle @relation(fields: [vehicleId], references: [id])

  assignmentType    AssignmentType @default(BOTH)

  monthlyFee        Float

  startDate         DateTime
  endDate           DateTime?

  status            AssignmentStatus @default(ACTIVE)

  tenantId          String @db.ObjectId
  tenant            Tenant @relation(fields: [tenantId], references: [id])

  attendances       TransportAttendance[]
  studentPickupDrops StudentPickupDrop[]

  isDeleted         Boolean @default(false)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@index([studentId])
  @@index([vehicleId])
  @@index([routeId])
}

model TransportAttendance {

  id               String @id @default(auto()) @map("_id") @db.ObjectId

  assignmentId     String @db.ObjectId
  assignment       TransportAssignment @relation(fields: [assignmentId], references: [id])

  date             DateTime

  status           AttendanceStatus

  type             AttendanceType

  remarks          String?

  markedBy         String

  tenantId         String @db.ObjectId
  tenant           Tenant @relation(fields: [tenantId], references: [id])

  isDeleted        Boolean @default(false)

  createdAt        DateTime @default(now())

  @@index([tenantId])
  @@index([assignmentId, date])
}

model TransportSetting {

  id                     String @id @default(auto()) @map("_id") @db.ObjectId

  tenantId               String @unique @db.ObjectId
  tenant                 Tenant @relation(fields: [tenantId], references: [id])

  lateFinePerDay         Float @default(0)

  absentNotification     Boolean @default(true)

  gpsTrackingEnabled     Boolean @default(false)

  smsAlertEnabled        Boolean @default(false)

  maxStudentsPerVehicle  Int @default(50)

  // Online Tracking Settings
  trackingInterval       Int @default(15)       // seconds
  geofenceRadius         Float @default(200)    // meters
  speedLimit             Int @default(60)       // km/h
  sosEnabled             Boolean @default(true)
  parentAppEnabled       Boolean @default(true)

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

