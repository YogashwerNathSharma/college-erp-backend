model PeriodMaster {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId  String   @db.ObjectId
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  name      String   // "Period 1", "Lunch Break"
  number    Int      // Order sequence
  startTime String   // "08:00"
  endTime   String   // "08:40"
  duration  Int      // Minutes, e.g. 40
  type      String   // REGULAR | BREAK | LUNCH | FREE

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timetableSlots TimetableSlotMaster[]

  @@index([tenantId])
}

model TimetableSlotMaster {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId   String   @db.ObjectId
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  dayOfWeek  Int      // 0=Sunday ... 6=Saturday
  periodId   String   @db.ObjectId
  period     PeriodMaster @relation(fields: [periodId], references: [id])
  classId    String   @db.ObjectId
  sectionId  String   @db.ObjectId
  subjectId  String?  @db.ObjectId
  teacherId  String?  @db.ObjectId
  roomId     String?  @db.ObjectId

  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([periodId])
  @@index([classId, sectionId, dayOfWeek])
  @@index([teacherId])
}


