model AIPromptMaster {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String   @db.ObjectId
  tenant   Tenant   @relation(fields: [tenantId], references: [id])

  name     String   // "Attendance Analysis", "Fee Defaulter Prediction", "Report Summary"
  prompt   String   // The actual AI prompt template with {{variable}} placeholders
  module   String   // Module context: "ATTENDANCE", "FEES", "EXAM", "GENERAL"
  type     String   // ANALYSIS | PREDICTION | GENERATION

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model PredictionRuleMaster {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId  String   @db.ObjectId
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  name      String   // "Fee Defaulter Alert", "Dropout Risk", "Low Attendance Alert"
  module    String   // "FEES", "STUDENTS", "ATTENDANCE"
  condition Json     // { "field": "attendance_percentage", "operator": "lt", "value": 75 }
  action    String   // "NOTIFY_ADMIN" | "SEND_SMS" | "FLAG_STUDENT" | "CREATE_TASK"
  threshold Float    // Confidence threshold (0.0 to 1.0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model AnalyticsRuleMaster {
