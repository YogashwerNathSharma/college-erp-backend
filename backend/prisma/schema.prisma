// 💰 FEES MODULE (Dynamic — Admin-Defined)
// ═══════════════════════════════════════════════════════════════

//////////////////////
// FEE HEAD (Master — Admin defines fee types)
//////////////////////
model FeeHead {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String      @db.ObjectId
  name        String      // "Tuition Fee", "Lab Fee", "Transport Fee"
  code        String?     // Short code: "TF", "LF", "TR"
  description String?
  type        FeeHeadType @default(RECURRING)
  category    String?     // Academic, Transport, Hostel, Examination, Library, Misc, Security, Registration, Admission
  frequency   String?     // Monthly, Quarterly, HalfYearly, Yearly, OneTime, Custom
  isTaxable   Boolean     @default(false)
  isRefundable Boolean    @default(false)
  sourceModule String?    // Admission, Transport, Hostel, Library, Examination, Manual, Accounts

  tenant Tenant @relation(fields: [tenantId], references: [id])

  structureItems FeeStructureItem[]
  studentFees    StudentFee[]
  studentFeeItems StudentFeeItem[]

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

enum FeeHeadType {
  RECURRING
  ONE_TIME
}

//////////////////////
// FEE STRUCTURE (Class + AcademicYear wise fee plan)
//////////////////////
model FeeStructure {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  tenantId        String          @db.ObjectId
  academicYearId  String          @db.ObjectId
  classId         String          @db.ObjectId

  name              String        // "Class 1 Fee 2025-26"
  totalAmount       Float         // Sum of all head amounts
  installmentType   InstallmentType @default(MONTHLY)
  totalInstallments Int           @default(12)
  dueDay            Int           @default(10) // Day of month fee is due

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  class        Class        @relation(fields: [classId], references: [id])

  items       FeeStructureItem[]
  studentFees StudentFee[]

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, classId, academicYearId])
  @@index([tenantId, academicYearId])
}

enum InstallmentType {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  ONE_TIME
  CUSTOM
}

//////////////////////
// FEE STRUCTURE ITEM (Head-wise breakdown)
//////////////////////
model FeeStructureItem {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  feeStructureId String @db.ObjectId
  feeHeadId      String @db.ObjectId

  amount    Float
  frequency String @default("PER_INSTALLMENT") // PER_INSTALLMENT or ONE_TIME

  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  feeHead      FeeHead      @relation(fields: [feeHeadId], references: [id])

  @@unique([feeStructureId, feeHeadId])
}

//////////////////////
// FEE DISCOUNT (Master — Discount types)
//////////////////////
model FeeDiscount {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String       @db.ObjectId
  name        String       // "Sibling Discount", "Merit Scholarship"
  type        DiscountType
  value       Float        // 10 = 10% or ₹10 based on type
  description String?

  applicableHeadIds String[] @db.ObjectId // Empty = all heads

  tenant Tenant @relation(fields: [tenantId], references: [id])

  studentFeeDiscounts StudentFeeDiscount[]

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

//////////////////////
// FINE RULE (Late payment penalty)
//////////////////////
model FineRule {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  tenantId     String @db.ObjectId
  name         String
  afterDays    Int    // Fine starts X days after due
  amountPerDay Float  // ₹/day
  maxAmount    Float  // Cap

  tenant Tenant @relation(fields: [tenantId], references: [id])

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId])
}

//////////////////////
// STUDENT FEE (Assigned per student per installment)
//////////////////////
model StudentFee {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  tenantId       String @db.ObjectId
  enrollmentId   String @db.ObjectId
  feeStructureId String @db.ObjectId
  feeHeadId      String?  @db.ObjectId
  feeHead        FeeHead? @relation(fields: [feeHeadId], references: [id])

  totalAmount    Float
  discountAmount Float     @default(0)
  fineAmount     Float     @default(0)
  netAmount      Float
  paidAmount     Float     @default(0)
  balanceAmount  Float

  installmentNo  Int
  dueDate        DateTime
  status         FeeStatus @default(PENDING)

  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id])
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])

  payments  Payment[]
  discounts StudentFeeDiscount[]
  items     StudentFeeItem[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([enrollmentId, feeStructureId, installmentNo])
  @@index([tenantId, status])
  @@index([enrollmentId])
  @@index([tenantId, dueDate])
}

//////////////////////
// STUDENT FEE ITEM (Per-student fee head breakdown)
//////////////////////
model StudentFeeItem {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  studentFeeId  String @db.ObjectId
  feeHeadId     String @db.ObjectId

  name          String   // Fee head name (cached for quick access)
  amount        Float    // Amount for this fee head
  frequency     String   @default("PER_INSTALLMENT") // PER_INSTALLMENT or ONE_TIME

  studentFee    StudentFee @relation(fields: [studentFeeId], references: [id])
  feeHead       FeeHead    @relation(fields: [feeHeadId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentFeeId])
  @@index([feeHeadId])
}

enum FeeStatus {
  PENDING
  UNPAID
  PARTIAL
  PARTIALLY_PAID
  PAID
  OVERDUE
}

//////////////////////
// STUDENT FEE DISCOUNT (Applied discounts)
//////////////////////
model StudentFeeDiscount {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  studentFeeId  String @db.ObjectId
  feeDiscountId String @db.ObjectId
  amount        Float

  studentFee  StudentFee  @relation(fields: [studentFeeId], references: [id])
  feeDiscount FeeDiscount @relation(fields: [feeDiscountId], references: [id])

  createdAt DateTime @default(now())

  @@unique([studentFeeId, feeDiscountId])
}

//////////////////////
// PAYMENT (Fee collection records)
//////////////////////
model Payment {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  tenantId     String        @db.ObjectId
  studentFeeId String        @db.ObjectId

  amount       Float
  method       PaymentMethod
  reference    String?       // Txn ID, Cheque No, UPI ref
  remarks      String?

  receiptNo    String        @unique
  paymentDate  DateTime      @default(now())
  collectedBy  String?       @db.ObjectId

  studentFee StudentFee @relation(fields: [studentFeeId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  paymentMode  String?
  receiptNumber String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId])
  @@index([studentFeeId])
  @@index([tenantId, paymentDate])

}

enum PaymentMethod {
  CASH
  ONLINE
  UPI
  CHEQUE
  BANK_TRANSFER
  DD
}

