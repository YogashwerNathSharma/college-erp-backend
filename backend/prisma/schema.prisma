generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}




// ══════════════════════════════════
// TENANT (Fixed)
// ══════════════════════════════════
model Tenant {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Basic Info
  name          String
  type          String
  logoUrl       String?
  backgroundUrl String?
  address       String?
  phone         String?
  email         String?
  primaryColor  String?   @default("#4f46e5")

  // Core Relations
  users         User[]
  academicYears AcademicYear[]
  classes       Class[]
  sections      Section[]
  subjects      Subject[]
  teachers      Teacher[]
  timetables    Timetable[]

  // Student Module Relations
  students          Student[]
  studentDocuments  StudentDocument[]   // ← ADDED (was missing)
  enrollments       Enrollment[]
  studentHistories  StudentHistory[]
  promotions        Promotion[]
  classAgeConfigs   ClassAgeConfig[]
  admissionCounters AdmissionCounter[]

  // Fee Module Relations
  feeHeads      FeeHead[]
  feeStructures FeeStructure[]
  feeDiscounts  FeeDiscount[]
  fineRules     FineRule[]
  studentFees   StudentFee[]
  payments      Payment[]
freeTrialRecords FreeTrialRecord[]
  // Teacher Module Relations
  teacherLeaves       TeacherLeave[]
  teacherSalaries     TeacherSalary[]
  teacherPerformances TeacherPerformance[]
  teacherDocuments    TeacherDocument[]
  communications      Communication[]
  teacherSettings     TeacherSettings?    // 1:1 (ek tenant ka ek hi settings)

  // Attendance
  attendances Attendance[]

  // Subscription
  subscriptions         TenantSubscription[]
  currentSubscriptionId String? @db.ObjectId
  maxStudents           Int     @default(0)
  maxTeachers           Int     @default(0)
  maxAdmins             Int     @default(0)
  maxStorageInGB        Int     @default(0)
 /////exam
 examSchedules          ExamSchedule[]
seatingArrangements    SeatingArrangement[]
admitCards             AdmitCard[]
questionPapers         QuestionPaper[]
invigilatorAssignments InvigilatorAssignment[]

  // Status
  isActive  Boolean  @default(true)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rooms               Room[]
  ///library
  books            Book[]
bookCategories   BookCategory[]
libraryMembers   LibraryMember[]
bookIssues       BookIssue[]
librarySetting   LibrarySetting?

////////transport
vehicles                Vehicle[]
routes                  Route[]
routeStops              RouteStop[]
transportAssignments    TransportAssignment[]
transportAttendances    TransportAttendance[]
transportSetting        TransportSetting?
vehicleLocations        VehicleLocation[]
tripLogs                TripLog[]
geofenceAlerts          GeofenceAlert[]
studentPickupDrops      StudentPickupDrop[]
emergencyContacts       EmergencyContact[]
rolePermissions         RolePermission[]

  // Hostel Module Relations
  hostels              Hostel[]
  hostelRooms          HostelRoom[]
  hostelAllocations    HostelAllocation[]
  messMenus            MessMenu[]

  // Communication Module Relations
  notices              Notice[]
  smsLogs              SMSLog[]
  whatsAppLogs         WhatsAppLog[]
  pushNotifications    PushNotification[]

  // HR Module Relations
  staffAttendances     StaffAttendance[]
  leaves               Leave[]
  payrolls             Payroll[]

  // Asset Module Relations
  assets               Asset[]
  assetIssues          AssetIssue[]

  // Certificate Module Relations
  certificates         Certificate[]

  // Audit
  auditLogs            AuditLog[]

}

//////////////////////
// USER
//////////////////////
model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  email    String @unique
  password String
  role     String
  phone    String?          
  status   String  @default("ACTIVE")  
  tenantId String? @db.ObjectId
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
freeTrialRecords FreeTrialRecord[]
  isFirstLogin   Boolean   @default(true)
  resetOtp       String?
  resetOtpExpiry DateTime?
  createdAt      DateTime  @default(now())

  @@map("User")
}

// ══════════════════════════════════
// ACADEMIC YEAR (Fixed)
// ══════════════════════════════════
model AcademicYear {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  startDate DateTime
  endDate   DateTime

  isActive  Boolean @default(false)
  isCurrent Boolean @default(false)

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Core Relations
  classes     Class[]
  sections    Section[]
  subjects    Subject[]
  students    Student[]
  teachers    Teacher[]
  enrollments Enrollment[]

  // Fee Module
  feeStructures FeeStructure[]

  // Teacher Module
  teacherLeaves       TeacherLeave[]
  teacherSalaries     TeacherSalary[]
  teacherPerformances TeacherPerformance[]
  teacherSettings     TeacherSettings[]

  // Student Module
  admissionCounters AdmissionCounter[]

  // Attendance
  attendances Attendance[]

  // Soft Delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////
// CLASS
//////////////////////
model Class {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  teachers        TeacherClass[]
  subjects        Subject[]
  sections        Section[]
  enrollments     Enrollment[]
  timetables      Timetable[]
  classAgeConfigs ClassAgeConfig[]
  feeStructures   FeeStructure[]

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
}

//////////////////////
// SECTION
//////////////////////
model Section {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  classId        String @db.ObjectId
  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  class        Class        @relation(fields: [classId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  enrollments Enrollment[]
  timetables  Timetable[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

//////////////////////
// STUDENT
//////////////////////

model Student {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  firstName String
  lastName  String
  gender    String
  dob       DateTime

  bloodGroup String?
  religion   String?
  caste      String?
  category   String?

  nationality String @default("Indian")

  aadharNo String?
  email    String?
  phone    String?

  address String

  admissionNo String
  srNo        String?
  rollNumber  String?

  admissionDate DateTime @default(now())

  fatherName       String
  motherName       String
  fatherPhone      String
  motherPhone      String?
  fatherOccupation String?
  motherOccupation String?

  guardianName     String?
  guardianPhone    String?
  guardianRelation String?

  photoUrl String?

  // Relations
  documents        StudentDocument[]
  enrollments      Enrollment[]
  studentHistories StudentHistory[]
  promotions       Promotion[]

  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  status String @default("active")

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  seatingArrangements    SeatingArrangement[]
  admitCards             AdmitCard[]
  @@unique([admissionNo, tenantId])
  @@index([srNo, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, academicYearId])
}

//////////////////////
// STUDENT DOCUMENT
//////////////////////
model StudentDocument {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  studentId String @db.ObjectId
  tenantId  String @db.ObjectId

  type String
  name String
  url  String

  mimeType String?
  size     Int?

  student Student @relation(fields: [studentId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  uploadedAt DateTime @default(now())

  isDeleted Boolean @default(false)

  @@index([studentId])
  @@index([tenantId, type])
}

//////////////////////
// ENROLLMENT
//////////////////////
model Enrollment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  studentId      String @db.ObjectId
  classId        String @db.ObjectId
  sectionId      String @db.ObjectId
  academicYearId String @db.ObjectId
  tenantId       String @db.ObjectId

  rollNumber String?
  status     String @default("active")

  student      Student      @relation(fields: [studentId], references: [id])
  class        Class        @relation(fields: [classId], references: [id])
  section      Section      @relation(fields: [sectionId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])

  studentFees StudentFee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@unique([studentId, academicYearId])
  @@index([classId, sectionId, academicYearId])
  @@index([tenantId, academicYearId])
}

//////////////////////
// STUDENT HISTORY
//////////////////////
model StudentHistory {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  studentId String @db.ObjectId
  tenantId  String @db.ObjectId

  action  String
  details String @default("{}")
  message String?

  fromClassId   String?
  toClassId     String?
  fromSectionId String?
  toSectionId   String?

  academicYearId String?

  performedBy String

  student Student @relation(fields: [studentId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([tenantId, action])
}

model Promotion {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  studentId String @db.ObjectId
  tenantId  String @db.ObjectId

  fromClassId        String
  fromSectionId      String
  fromAcademicYearId String

  toClassId          String
  toSectionId        String
  toAcademicYearId   String

  promotionType String
  type          String

  remarks String?

  promotedBy String

  student Student @relation(fields: [studentId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  promotedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([tenantId, fromAcademicYearId])
  @@index([studentId])
}

//////////////////////
// ADMISSION COUNTER
//////////////////////
model AdmissionCounter {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  prefix String @default("ADM")

  lastNumber Int @default(0)

  format String @default("PREFIX/YEAR/SERIAL")
  academicYear AcademicYear @relation(fields: [academicYearId],references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, academicYearId])
}
//////////////////////
// CLASS AGE CONFIG
//////////////////////
model ClassAgeConfig {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  tenantId String @db.ObjectId
  classId  String @db.ObjectId

  board BoardType

  className String

  minAge Float
  maxAge Float

  ageCalcRefMonth Int @default(3)
  ageCalcRefDay   Int @default(31)

  isActive Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  class  Class  @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, classId, board])
  @@index([tenantId, board])
}

enum BoardType {
  UP_BOARD
  CBSE
  ICSE
  STATE_BOARD
  IB
  IGCSE
}

//////////////////////
// SUBJECT
//////////////////////
model Subject {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  classId        String @db.ObjectId
  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  class        Class        @relation(fields: [classId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  teachers   TeacherSubject[]
  timetables Timetable[]
  examSchedules          ExamSchedule[]
  questionPapers         QuestionPaper[]
  periodsPerWeek Int      @default(6)
  isActive       Boolean  @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt      DateTime @default(now())
}

//////////////////////
// TEACHER
//////////////////////

model Teacher {
  id    String @id @default(auto()) @map("_id") @db.ObjectId

  // Basic Information
  firstName String
  lastName  String
  name      String // Auto: firstName + " " + lastName

  email String @unique
  phone String

  // Personal Information
  gender        String? // Male | Female | Other
  dob           DateTime?
  employeeId    String? // TCH001
  maritalStatus String? // Single | Married | Divorced | Widowed
  photoUrl      String?

  // Multi-Tenant Fields
  tenantId       String @db.ObjectId
  academicYearId String @db.ObjectId

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  // Relations
  subjects      TeacherSubject[]
  classes       TeacherClass[]
  timetables    Timetable[]

  leaves        TeacherLeave[]
  salaries      TeacherSalary[]
  performances  TeacherPerformance[]
  documents     TeacherDocument[]
  invigilatorAssignments InvigilatorAssignment[]
  // Soft Delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Audit
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([academicYearId])
  @@index([employeeId])
}

//////////////////////
// TeacherSubject
//////////////////////
model TeacherSubject {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  teacherId String @db.ObjectId
  subjectId String @db.ObjectId

  teacher Teacher @relation(fields: [teacherId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

//////////////////////
// TeacherClass
//////////////////////
model TeacherClass {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  teacherId String @db.ObjectId
  classId   String @db.ObjectId

  teacher Teacher @relation(fields: [teacherId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

//////////////////////
// ATTENDANCE
//////////////////////
enum AttendanceStatus {
  PRESENT
  ABSENT
}

model Attendance {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId

  studentId      String   @db.ObjectId
  classId        String   @db.ObjectId
  sectionId      String   @db.ObjectId
  tenantId       String   @db.ObjectId
  tenant Tenant  @relation(fields: [tenantId], references: [id])
  academicYearId String   @db.ObjectId
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  date           DateTime
  status         AttendanceStatus

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  isDeleted      Boolean  @default(false)
  deletedAt      DateTime?

  @@index([studentId, date])
  @@index([classId, sectionId, date])
}
// ======================
// ENUMS
// ======================

enum LeaveType {
  CASUAL
  MEDICAL
  EARNED
  MATERNITY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SalaryStatus {
  PENDING
  PAID
}

enum DocumentType {
  PERSONAL
  IDENTITY
  ACADEMIC
  EXPERIENCE
}

enum SenderType {
  ADMIN
  PRINCIPAL
  SYSTEM
}

// ======================
// TEACHER LEAVE
// ======================

model TeacherLeave {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  teacherId      String        @db.ObjectId
  leaveType      LeaveType
  fromDate       DateTime
  toDate         DateTime
  days           Int
  reason         String
  status         LeaveStatus   @default(PENDING)
  approvedBy     String?       @db.ObjectId
  tenantId       String        @db.ObjectId
  academicYearId String        @db.ObjectId

  teacher        Teacher       @relation(fields: [teacherId], references: [id])
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id])

  isDeleted      Boolean       @default(false)
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([teacherId, status])
  @@index([tenantId, academicYearId])
}

// ======================
// TEACHER SALARY
// ======================

model TeacherSalary {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  teacherId        String        @db.ObjectId
  month            Int
  year             Int

  basicSalary      Float

  allowances       Json
  deductions       Json

  totalAllowances  Float
  totalDeductions  Float
  netSalary        Float

  status           SalaryStatus @default(PENDING)
  paidAt           DateTime?

  tenantId         String        @db.ObjectId
  academicYearId   String        @db.ObjectId

  teacher          Teacher       @relation(fields: [teacherId], references: [id])
  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  academicYear     AcademicYear  @relation(fields: [academicYearId], references: [id])

  isDeleted        Boolean       @default(false)
  deletedAt        DateTime?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([teacherId, month, year])
  @@index([tenantId, academicYearId])
}

// ======================
// TEACHER PERFORMANCE
// ======================

model TeacherPerformance {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  teacherId        String        @db.ObjectId
  academicYearId   String        @db.ObjectId
  tenantId         String        @db.ObjectId

  parameters       Json
  overallRating    Float
  remarks          String?

  evaluatedBy      String?       @db.ObjectId

  teacher          Teacher       @relation(fields: [teacherId], references: [id])
  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  academicYear     AcademicYear  @relation(fields: [academicYearId], references: [id])

  isDeleted        Boolean       @default(false)
  deletedAt        DateTime?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([teacherId, academicYearId])
}

// ======================
// TEACHER DOCUMENT
// ======================

model TeacherDocument {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  teacherId     String       @db.ObjectId

  name          String
  type          DocumentType
  fileUrl       String

  uploadDate    DateTime     @default(now())

  tenantId      String       @db.ObjectId

  teacher       Teacher      @relation(fields: [teacherId], references: [id])
  tenant        Tenant       @relation(fields: [tenantId], references: [id])

  isDeleted     Boolean      @default(false)
  deletedAt     DateTime?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// ======================
// COMMUNICATION
// ======================

model Communication {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId

  title         String
  message       String

  senderType    SenderType
  senderName    String

  tenantId      String       @db.ObjectId

  tenant        Tenant       @relation(fields: [tenantId], references: [id])

  isDeleted     Boolean      @default(false)
  deletedAt     DateTime?

  createdAt     DateTime     @default(now())
}

// ======================
// TEACHER SETTINGS
// ======================

model TeacherSettings {
  id                     String        @id @default(auto()) @map("_id") @db.ObjectId

  tenantId               String        @unique @db.ObjectId
  academicYearId         String        @db.ObjectId

  // General Settings
  dateFormat             String        @default("DD/MM/YYYY")
  timeFormat             String        @default("24 Hour")

  // Attendance Settings
  attendanceRequired     Boolean       @default(true)
  lateMarkTime           String        @default("09:30")
  halfDayTime            String        @default("13:00")

  // Leave Settings
  casualLeavePerYear     Int           @default(12)
  medicalLeavePerYear    Int           @default(10)
  earnedLeavePerYear     Int           @default(15)

  // Salary Settings
  payDay                 Int           @default(1)
  salarySlipTemplate     String        @default("default")

  // Notification Settings
  emailNotifications     Boolean       @default(true)
  smsNotifications       Boolean       @default(false)

  tenant                Tenant         @relation(fields: [tenantId], references: [id])
  academicYear          AcademicYear   @relation(fields: [academicYearId], references: [id])

  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

//////////////////////
// TIMETABLE
//////////////////////
enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

model Timetable {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  classId   String @db.ObjectId
  sectionId String @db.ObjectId
  subjectId String @db.ObjectId
  teacherId String @db.ObjectId
  tenantId  String @db.ObjectId

  day    DayOfWeek
  period Int

  class   Class   @relation(fields: [classId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([classId, sectionId, day, period])
}

//////////////////////
// EXAM
//////////////////////
model Exam {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  type            String?
  classId         String    @db.ObjectId
  sectionId       String?   @db.ObjectId
  academicYearId  String    @db.ObjectId
  tenantId        String    @db.ObjectId
  startDate       DateTime?
  endDate         DateTime?
  resultType      String    @default("BOTH")
  examSchedules          ExamSchedule[]
  admitCards             AdmitCard[]
  questionPapers         QuestionPaper[]
  isPublished     Boolean   @default(false)
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─────────────── REPLACE your old ExamSubject model ───────────────
model ExamSubject {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  examId        String  @db.ObjectId
  subjectId     String  @db.ObjectId
  tenantId      String  @db.ObjectId
  maxMarks      Int
  passingMarks  Int
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
}

// ─────────────── NEW — Replace old Result model ───────────────
model MarksEntry {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  examId          String   @db.ObjectId
  studentId       String   @db.ObjectId
  subjectId       String   @db.ObjectId
  tenantId        String   @db.ObjectId
  marksObtained   Float
  isAbsent        Boolean  @default(false)
  isDeleted       Boolean  @default(false)
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────── NEW — Grade Settings ───────────────
model GradeSetting {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String  @db.ObjectId
  grade       String
  minPercent  Float
  maxPercent  Float
  gradePoint  Float?
  remarks     String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─────────────── NEW — Result Summary ───────────────
model ResultSummary {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  examId          String  @db.ObjectId
  studentId       String  @db.ObjectId
  tenantId        String  @db.ObjectId
