model CertificateTemplateMaster {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String   @db.ObjectId
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  name        String
  type        String   // TC | CC | MIGRATION | BONAFIDE | CUSTOM
  content     String   // HTML template body with {{variable}} placeholders
  headerHtml  String?  // Custom header HTML (school letterhead)
  footerHtml  String?  // Custom footer HTML (signatures, seals)
  variables   String[] // Available merge variables: ["studentName", "fatherName", "class", ...]
  paperSize   String   @default("A4") // A4 | LETTER | LEGAL
  orientation String   @default("PORTRAIT") // PORTRAIT | LANDSCAPE

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model IDCardTemplateMaster {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String   @db.ObjectId
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  name        String
  type        String   // STUDENT | STAFF | VISITOR
  frontDesign String   // JSON or HTML template for front side
  backDesign  String   // JSON or HTML template for back side
  size        String   @default("STANDARD") // STANDARD (CR80) | CUSTOM
  orientation String   @default("PORTRAIT") // PORTRAIT | LANDSCAPE

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}


// ┌──────────────────────────────────────────────────────────────┐
// │  15. USER & SECURITY MASTERS                                 │
