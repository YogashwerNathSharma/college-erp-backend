// ══════════════════════════════════════════════════════════
// FILE MANAGER - Prisma Models
// ══════════════════════════════════════════════════════════

model FileStorage {
  id           String @id @default(auto()) @map("_id") @db.ObjectId

  fileName     String  // stored filename (uuid + extension)
  originalName String  // user's original filename
  path         String  // relative path in uploads/
  url          String  // full URL to access
  mimeType     String  // image/png, application/pdf, etc.
  size         Int     // in bytes
  extension    String  // png, pdf, docx, etc.

  // Categorization
  category     String  // STUDENT_PHOTO, DOCUMENT, CERTIFICATE, HOMEWORK, STAFF, GENERAL, ATTACHMENT
  folderId     String? @db.ObjectId

  // Entity association (optional - links file to specific record)
  entityId     String? @db.ObjectId
  entityType   String? // Student, Teacher, Certificate, etc.

  // Metadata
  uploadedBy   String @db.ObjectId
  uploadedByName String?
  description  String?
  tags         String[] // searchable tags

  // Status
  isPublic     Boolean @default(false)
  isDeleted    Boolean @default(false)
  deletedAt    DateTime?
  deletedBy    String? @db.ObjectId

  // Tenant
  tenantId     String @db.ObjectId
  tenant       Tenant @relation(fields: [tenantId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, category])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, folderId])
  @@index([tenantId, isDeleted])
}

model FileFolder {
  id        String @id @default(auto()) @map("_id") @db.ObjectId

  name      String
  parentId  String? @db.ObjectId // null = root folder
  path      String  // full path like "/Documents/Students/2024"
  color     String? // folder color
  icon      String? // folder icon

  createdBy String @db.ObjectId
  createdByName String?

  isActive  Boolean @default(true)

  // Tenant
  tenantId  String @db.ObjectId
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, parentId])
  @@index([tenantId, path])
}


