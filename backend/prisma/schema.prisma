// ──────────────────────────────────────────
// VehicleLocation — Real-time GPS tracking
// ──────────────────────────────────────────
model VehicleLocation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  vehicleId   String   @db.ObjectId
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])

  latitude    Float
  longitude   Float
  speed       Float?
  heading     Float?
  altitude    Float?
  accuracy    Float?

  timestamp   DateTime

  tenantId    String   @db.ObjectId
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([vehicleId, timestamp])
  @@index([tenantId])
  @@unique([vehicleId, tenantId])
}

// ──────────────────────────────────────────
// TripLog — Trip history
// ──────────────────────────────────────────
model TripLog {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId

  vehicleId     String     @db.ObjectId
  vehicle       Vehicle    @relation(fields: [vehicleId], references: [id])

  routeId       String     @db.ObjectId

  driverName    String

  startTime     DateTime
  endTime       DateTime?

  startLat      Float
  startLng      Float
  endLat        Float?
  endLng        Float?

  totalDistance  Float?

  status        TripStatus @default(ONGOING)

  tenantId      String     @db.ObjectId
  tenant        Tenant     @relation(fields: [tenantId], references: [id])

  geofenceAlerts GeofenceAlert[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([vehicleId, startTime])
  @@index([tenantId])
}

// ──────────────────────────────────────────
// GeofenceAlert — Geofence violation alerts
// ──────────────────────────────────────────
model GeofenceAlert {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId

  vehicleId   String    @db.ObjectId
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])

  tripId      String?   @db.ObjectId
