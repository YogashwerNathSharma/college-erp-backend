// ┌─────────────────────────────────────────────────────────────────────────┐
// │ 7. ATTENDANCE MASTERS                                                   │
// └─────────────────────────────────────────────────────────────────────────┘

model AttendanceStatusMaster {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId       String   @db.ObjectId
  tenant         Tenant   @relation(fields: [tenantId], references: [id])

  name           String   // PRESENT | ABSENT | LATE | HALF_DAY | LEAVE | HOLIDAY
  code           String   // Short code: P, A, L, HD, LV, H
  color          String   // Hex color for UI display e.g. "#22c55e" for present
  countAsPresent Boolean  @default(false) // Whether this status counts toward attendance %

  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, code])
  @@map("attendance_status_masters")
}

model LateFineMaster {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId     String   @db.ObjectId
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  afterMinutes Int      // Fine applies after these many minutes late
  fineAmount   Float    // Fine amount in INR
  frequency    String   // DAILY | WEEKLY | MONTHLY (how often fine is applied)

  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@map("late_fine_masters")
}

model LeaveReasonMaster {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId         String   @db.ObjectId
  tenant           Tenant   @relation(fields: [tenantId], references: [id])

  name             String   // e.g. "Medical", "Family Emergency", "Personal"
  requiresDocument Boolean  @default(false) // Whether document upload is mandatory
  maxDays          Int?     // Maximum days allowed for this reason (optional)

  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
  @@map("leave_reason_masters")
}

model AttendanceShiftMaster {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId     String   @db.ObjectId
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  name         String   // e.g. "Morning Shift", "Afternoon Shift"
  startTime    String   // HH:MM format e.g. "08:00"
  endTime      String   // HH:MM format e.g. "14:00"
  graceMinutes Int      @default(15) // Grace period in minutes before marking late

  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@map("attendance_shift_masters")
}


