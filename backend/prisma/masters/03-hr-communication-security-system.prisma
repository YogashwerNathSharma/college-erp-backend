model ThemeMaster {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId       String   @db.ObjectId
  tenant         Tenant   @relation(fields: [tenantId], references: [id])

  name           String   // "Default Blue", "School Green", "Dark Mode"
  primaryColor   String   // "#4f46e5"
  secondaryColor String   // "#10b981"
  accentColor    String   // "#f59e0b"
  fontFamily     String   @default("Inter") // "Inter" | "Poppins" | "Roboto"
  isDark         Boolean  @default(false)
  isDefault      Boolean  @default(false) // Only one theme can be default per tenant

  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
}

