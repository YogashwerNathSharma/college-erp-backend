  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  name          String   // "Monthly Fee Trend", "Class Performance Index"
  module        String   // "FEES", "EXAM", "ATTENDANCE"
  metric        String   // "total_collected", "average_marks", "attendance_rate"
  formula       String   // Calculation formula: "SUM(amount) WHERE status='PAID'"
  visualization String   // "LINE_CHART" | "BAR_CHART" | "PIE_CHART" | "NUMBER" | "TABLE"

  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}


