// ──────────────────────────────────────────────────────────────
// GATE PASS MODULE
// ──────────────────────────────────────────────────────────────

model GatePass {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId       String   @db.ObjectId
  tenant         Tenant   @relation(fields: [tenantId], references: [id])

  visitorName    String
  visitorPhone   String
  purpose        String
  visitingPerson String
  department     String?
  entryTime      DateTime?
  exitTime       DateTime?
  vehicleNumber  String?
  idProofType    String?
  idProofNumber  String?
  photo          String?
  status         String   @default("PENDING") // PENDING, APPROVED, IN, OUT, COMPLETED, REJECTED
  approvedBy     String?
  notes          String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model GatePassSetting {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId                String   @unique @db.ObjectId
  tenant                  Tenant   @relation(fields: [tenantId], references: [id])

  requireApproval         Boolean  @default(true)
  autoApproveAfterMinutes Int?
  notifyOnEntry           Boolean  @default(true)
  notifyOnExit            Boolean  @default(false)
  allowedPurposes         String[] @default(["Meeting", "Delivery", "Interview", "Parent Visit", "Vendor", "Other"])
  workingHoursStart       String?  @default("08:00")
  workingHoursEnd         String?  @default("18:00")

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────
// EVENT MANAGEMENT MODULE
// ──────────────────────────────────────────────────────────────

model Event {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId     String   @db.ObjectId
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  title        String
  description  String?
  type         String   @default("OTHER") // ACADEMIC, CULTURAL, SPORTS, HOLIDAY, EXAM, MEETING, OTHER
  startDate    DateTime
  endDate      DateTime
  startTime    String?
  endTime      String?
  venue        String?
  organizer    String?
  participants String[] @default([])
  isPublic     Boolean  @default(true)
  status       String   @default("UPCOMING") // UPCOMING, ONGOING, COMPLETED, CANCELLED
  attachments  String[] @default([])
  budget       Float?
  actualCost   Float?
  notes        String?
  color        String?  @default("#4f46e5")

  categoryId   String?  @db.ObjectId
  category     EventCategory? @relation(fields: [categoryId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, startDate])
  @@index([tenantId, status])
  @@index([tenantId, type])
}

model EventCategory {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String   @db.ObjectId
  tenant   Tenant   @relation(fields: [tenantId], references: [id])

  name     String
  color    String   @default("#4f46e5")
  icon     String?
  events   Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ──────────────────────────────────────────────────────────────
// HELP DESK MODULE
// ──────────────────────────────────────────────────────────────

model Ticket {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId     String   @db.ObjectId
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  ticketNumber String
  title        String
  description  String
  category     String
  priority     String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status       String   @default("OPEN")   // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  raisedBy     String
  raisedByRole String?
  assignedTo   String?
  resolution   String?
  resolvedAt   DateTime?
  closedAt     DateTime?
  attachments  String[] @default([])

  comments     TicketComment[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@index([tenantId, ticketNumber])
}

model TicketComment {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  ticketId String   @db.ObjectId
  ticket   Ticket   @relation(fields: [ticketId], references: [id])

  message  String
  author   String
  authorRole String?
  isInternal Boolean @default(false)

  createdAt DateTime @default(now())
}

model TicketCategory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String   @db.ObjectId
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  name        String
  description String?
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

