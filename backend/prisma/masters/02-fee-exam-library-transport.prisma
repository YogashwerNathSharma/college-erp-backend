// ══════════════════════════════════════════════════════════════════════════════
// MASTER MODELS - Part 2
// Fee, Examination, Attendance, Library, Hostel, Transport, Inventory Masters
// ══════════════════════════════════════════════════════════════════════════════
// DATABASE: MongoDB with Prisma ORM
// ALL models have tenantId relation to Tenant
// Append these to: backend/prisma/schema.prisma
// ══════════════════════════════════════════════════════════════════════════════


// ┌─────────────────────────────────────────────────────────────────────────┐
// │ 5. FEE MASTERS                                                          │
// └─────────────────────────────────────────────────────────────────────────┘

model FeeGroupMaster {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String   @db.ObjectId
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  name        String
  description String?
  classes     String[] // Array of class IDs or class names this fee group applies to

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@map("fee_group_masters")
}

model FeeTypeMaster {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId     String   @db.ObjectId
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  name         String
  code         String
  isRefundable Boolean  @default(false)
  isMandatory  Boolean  @default(true)

  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, code])
  @@map("fee_type_masters")
}

model ConcessionMaster {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId   String   @db.ObjectId
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  name       String
  type       String   // PERCENTAGE | AMOUNT
  value      Float    // If PERCENTAGE: e.g. 10 means 10%, If AMOUNT: flat discount amount
  reason     String?
  categoryId String?  @db.ObjectId // Optional: link to CategoryMaster for category-based concessions
  criteria   String?  // JSON or text describing eligibility criteria

  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@map("concession_masters")
}

model ScholarshipMaster {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String   @db.ObjectId
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  name        String
  provider    String   // Who provides the scholarship (Govt/Trust/School/NGO)
  type        String   // MERIT | NEED | SPORTS | MINORITY
  amount      Float    // Fixed scholarship amount
  percentage  Float?   // Alternative: percentage-based scholarship
  criteria    String?  // Eligibility criteria description or JSON
  maxStudents Int?     // Maximum students who can avail this scholarship

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@map("scholarship_masters")
}

model PaymentModeMaster {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String   @db.ObjectId
  tenant   Tenant   @relation(fields: [tenantId], references: [id])

  name     String   // CASH | CHEQUE | ONLINE | UPI | CARD | BANK_TRANSFER
  code     String

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, code])
  @@map("payment_mode_masters")
}

model ReceiptSeriesMaster {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId      String   @db.ObjectId
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  prefix        String   // e.g. "REC-", "FEE-"
  startNumber   Int      // Starting receipt number
  currentNumber Int      // Current (next to use) receipt number
  suffix        String?  // Optional suffix
  format        String   // Format pattern e.g. "PREFIX-YYYY-NNNN" or "PREFIX/NNNN/SUFFIX"

  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@map("receipt_series_masters")
}


