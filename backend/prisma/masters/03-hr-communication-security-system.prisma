  name     String   // "Students", "Fees", "Attendance"
  code     String   // "STUDENTS", "FEES", "ATTENDANCE"
  icon     String   // Lucide icon name: "users", "indian-rupee", "clipboard-check"
  route    String   // Frontend route: "/students", "/fees/dashboard"
  order    Int      @default(0) // Display order in sidebar
  parentId String?  @db.ObjectId // For sub-modules (null = top-level)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@unique([tenantId, code])
}

model MenuMaster {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
