// ══════════════════════════════════════════════════════════════════════════════
// STUDENT VACCINATION RECORDS
// ══════════════════════════════════════════════════════════════════════════════
model StudentVaccination {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId

  studentId      String    @db.ObjectId
  tenantId       String    @db.ObjectId

  vaccineName    String         // e.g., "BCG", "Polio", "Hepatitis B", "MMR", "COVID-19"
  doseNumber     Int            // 1, 2, 3 (dose sequence)
  dateGiven      DateTime
  nextDueDate    DateTime?
  hospital       String?
  doctorName     String?
  batchNo        String?        // vaccine batch/lot number
  remarks        String?
  documentUrl    String?        // uploaded certificate/proof
  isCompleted    Boolean   @default(true)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  student        Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, tenantId])
  @@index([tenantId, nextDueDate])
}


// ══════════════════════════════════════════════════════════════════════════════
// STUDENT SIBLING RECORDS
// ══════════════════════════════════════════════════════════════════════════════
model StudentSibling {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId

  studentId         String    @db.ObjectId
  tenantId          String    @db.ObjectId

  siblingStudentId  String?   @db.ObjectId    // if sibling is also enrolled in same school
  name              String
  relation          String         // "brother" | "sister" | "step_brother" | "step_sister"
  className         String?        // class name (free text if not in system)
  school            String?        // school name (if different school)
  dob               DateTime?
  gender            String?
  admissionNo       String?        // if in same system

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  student           Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, tenantId])
  @@index([siblingStudentId, tenantId])
}


// ══════════════════════════════════════════════════════════════════════════════
// STUDENT COMMUNICATION LOG
// ══════════════════════════════════════════════════════════════════════════════
model StudentCommunicationLog {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId

  studentId      String    @db.ObjectId
  tenantId       String    @db.ObjectId

  type           String         // "sms" | "email" | "whatsapp" | "push" | "notice" | "call"
  subject        String?        // for emails
  message        String
  sentTo         String         // phone number or email address
  sentToName     String?        // recipient name (Father/Mother/Guardian/Student)
  sentBy         String         // userId who sent it
  sentByName     String?        // name of sender

  status         String    @default("queued")  // "queued" | "sent" | "delivered" | "failed" | "read"
  failureReason  String?
  deliveredAt    DateTime?
  readAt         DateTime?

  // Template info
  templateId     String?
  templateName   String?

  // Metadata (provider response, message ID, etc.)
  metadata       Json?

  sentAt         DateTime  @default(now())
  createdAt      DateTime  @default(now())

  // Relations
  student        Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, tenantId])
  @@index([tenantId, type, sentAt])
  @@index([tenantId, status])
}


// ══════════════════════════════════════════════════════════════════════════════
// STUDENT PORTAL CREDENTIALS
// ══════════════════════════════════════════════════════════════════════════════
model StudentCredential {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId

  studentId      String    @unique @db.ObjectId
  tenantId       String    @db.ObjectId

  username       String         // usually admissionNo or email
  passwordHash   String         // bcrypt hashed
  isActive       Boolean   @default(true)
  mustChangePassword Boolean @default(true)    // force password change on first login

  lastLogin      DateTime?
  lastLoginIp    String?
  loginCount     Int       @default(0)
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?      // account lockout after failed attempts

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  student        Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([username, tenantId])
  @@index([tenantId, isActive])
}


// ══════════════════════════════════════════════════════════════════════════════
// SAVED SEARCH FILTERS (per user, per tenant)
// ══════════════════════════════════════════════════════════════════════════════
model StudentSavedFilter {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId

  tenantId       String    @db.ObjectId
  userId         String    @db.ObjectId       // user who saved this filter

  name           String                        // "My Class 10 Filter", "Transport Boys", etc.
  description    String?

  // The actual filter configuration (stored as JSON)
  // Structure: { classId?, sectionId?, academicYearId?, status?, gender?, category?, 
  //              religion?, bloodGroup?, transport?, hostel?, houseId?, search?, 
  //              admissionDateFrom?, admissionDateTo?, dobFrom?, dobTo? }
  filters        Json

  isDefault      Boolean   @default(false)     // if true, auto-applied on page load
  isShared       Boolean   @default(false)     // visible to other users in same tenant
  sortOrder      Int       @default(0)         // for ordering in the dropdown

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId, userId])
  @@index([tenantId, isShared])
}


