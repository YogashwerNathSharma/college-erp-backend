// ============================================

// ══════════════════════════════════════════════════
// DIGITAL SIGNATURE - Prisma Models
// ══════════════════════════════════════════════════

model DigitalSignature {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId        String   @db.ObjectId
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  userId          String   @db.ObjectId
  name            String   // Signer name (e.g. "Dr. R.K. Sharma")
  designation     String   // "Principal", "HOD", "Clerk"
  department      String?
  
  // Signature images
  signatureImage  String   // Base64 or file URL of signature
  stampImage      String?  // Official stamp/seal image
  initialsImage   String?  // Short initials image
  
  // Metadata
  signatureType   String   @default("DRAWN") // DRAWN, UPLOADED, TYPED
  isDefault       Boolean  @default(false)
  
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  signedDocuments SignedDocument[]

  @@index([tenantId, userId])
}

model SignedDocument {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId        String   @db.ObjectId
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  documentId      String   // Reference to the document being signed
  documentType    String   // CERTIFICATE, REPORT_CARD, TC, BONAFIDE, NOTICE, LETTER
  documentTitle   String?
  
  // Signature reference
  signatureId     String   @db.ObjectId
  signature       DigitalSignature @relation(fields: [signatureId], references: [id])
  
  // Signer info (snapshot at time of signing)
  signedBy        String   // userId
  signerName      String
  signerDesignation String
  
  signedAt        DateTime @default(now())
  
  // Verification
  hash            String   // SHA-256 hash of document content at signing time
  verificationCode String  @unique // 8-char alphanumeric code for verification
  
  // QR for verification
  qrData          String?  // URL or data for verification QR
  
  // Status
  isValid         Boolean  @default(true)
  revokedAt       DateTime?
  revokeReason    String?

  createdAt       DateTime @default(now())

  @@index([tenantId, documentType])
  @@index([verificationCode])
}

