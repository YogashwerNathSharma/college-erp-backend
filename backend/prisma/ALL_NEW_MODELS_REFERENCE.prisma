  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, workflowId])
  @@index([tenantId, initiatedBy])
}

