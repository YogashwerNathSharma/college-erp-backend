// ══════════════════════════════════════════════════════════════════
// MASTER MODELS - Part 3
// HR, Communication, Certificate, User/Security, Document,
// Event, Visitor, AI, and System Masters
// ══════════════════════════════════════════════════════════════════
// DATABASE: MongoDB with Prisma ORM
// ALL models have tenantId + Tenant relation
// Append these to: backend/prisma/schema.prisma
// Also add corresponding relation arrays to the Tenant model
// ══════════════════════════════════════════════════════════════════


// ┌──────────────────────────────────────────────────────────────┐
// │  12. HR MASTERS                                              │
// └──────────────────────────────────────────────────────────────┘

model PayrollHeadMaster {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId  String   @db.ObjectId
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  name      String
  type      String   // EARNING | DEDUCTION
  isFixed   Boolean  @default(true)
  formula   String?  // e.g. "basic * 0.12" for PF

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model SalaryComponentMaster {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId        String   @db.ObjectId
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  name            String
  type            String   // BASIC | HRA | DA | TA | MEDICAL | PF_DEDUCTION | TAX | OTHER
  calculationType String   // FIXED | PERCENTAGE
  baseComponent   String?  // Reference component for percentage calc (e.g. "BASIC")
  percentage      Float?   // If calculationType is PERCENTAGE

  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
}

model PFMaster {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId              String   @db.ObjectId
  tenant                Tenant   @relation(fields: [tenantId], references: [id])

  employeeContribution  Float    // e.g. 12.0 (percentage)
  employerContribution  Float    // e.g. 12.0
  adminCharges          Float    @default(0) // e.g. 0.5
  ceiling               Float    // e.g. 15000 (max basic for PF calculation)

  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([tenantId])
}

model ESIMaster {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId              String   @db.ObjectId
  tenant                Tenant   @relation(fields: [tenantId], references: [id])

  employeeContribution  Float    // e.g. 0.75 (percentage)
  employerContribution  Float    // e.g. 3.25
  ceiling               Float    // e.g. 21000 (gross salary ceiling)

  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([tenantId])
}

model TaxSlabMaster {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId      String   @db.ObjectId
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  fromAmount    Float
  toAmount      Float
  percentage    Float
  surcharge     Float?   @default(0)
  cess          Float?   @default(4) // Health & Education Cess
  regime        String   // OLD | NEW
  financialYear String   // e.g. "2025-26"

  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}

model IncrementTypeMaster {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId   String   @db.ObjectId
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  name       String
  type       String   // ANNUAL | PROMOTION | SPECIAL
  percentage Float?
  amount     Float?

  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
}


